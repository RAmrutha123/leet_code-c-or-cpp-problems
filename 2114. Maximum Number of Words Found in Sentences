class Solution {
public:
    int mostWordsFound(vector<string>& sentences) {
        int n=sentences.size();
        int maxi=0;
        for(int i=0;i<n;i++){
            int c=1;
            for(auto a:sentences[i]){
            if(a == ' ')
                c++;
            }
            maxi=max(maxi,c);
        }
        return maxi;
    }
};
