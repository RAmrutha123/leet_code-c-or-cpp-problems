class Solution {
public:
    int numberOfSpecialChars(string word) {
        bool lower[26]={false};
        bool upper[26]={false};
        for(char ch:word){
            if(ch>='a'&&ch<='z'){
                lower[ch-'a']=true;
            }else if(ch>='A'&&ch<='Z'){
                upper[ch-'A']=true;
            }
        }
        int c=0;
        for(int i=0;i<26;i++){
            if(lower[i] && upper[i]){
                c++;
            }
        }
        return c;
    }
};
