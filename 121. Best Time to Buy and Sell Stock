class Solution {
public:
    int maxProfit(vector<int>& prices) {
        if (prices.empty()) {
            return 0; 
        }
        
        int buy = prices[0];
        int max = 0;
        
        for (int i = 1; i < prices.size(); i++) {
            int today = prices[i];
           
            if (today < buy) {
                buy = today;
            } 
            else {
                int potential = today - buy;
             
                if (potential > max) {
                    max = potential;
                }
            }
        }
        return max;
    }
};
