class Solution {
public:
    int differenceOfSum(vector<int>& nums) {
        int n=nums.size();
        int es=0,ds=0;
        for(int i=0;i<n;i++){
            es+=nums[i];
            int a=nums[i];
        while(a>0){
            ds+=a%10;
            a/=10;
        }
        }
        return abs(es-ds);
        
    }
};
