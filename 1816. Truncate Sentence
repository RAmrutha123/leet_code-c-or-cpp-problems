class Solution {
public:
    string truncateSentence(string s, int k) {
        int n=s.size();
        string ans = "";
        int c=0;
        for(int i=0;i<n;i++){
            if(s[i] == ' '){
             c++;
            }
            if(c==k) return ans;
              ans+=s[i];
        }  
        return ans;
    }
};
