class Solution {
public:
    int maximumWealth(vector<vector<int>>& accounts) {
        int maxwea=0;
        for(int i=0;i<accounts.size();i++){
            int currwea=0;
            for(int j=0;j<accounts[i].size();j++){
               currwea+=accounts[i][j];
            }
            maxwea=max(maxwea,currwea);
        }
        return maxwea;
    }
};
