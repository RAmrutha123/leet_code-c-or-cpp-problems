class Solution {
public:
    int dominantIndex(vector<int>& nums) {
        int n=nums.size();
        int max=-1,sm=-1,mi=-1;
        for(int i=0;i<n;i++){
            if(nums[i]>max){
                sm=max;
                max=nums[i];
                mi=i;
            }else if (nums[i]>sm){
                sm=nums[i];
            }
        }
        return (max>=2 *sm)?mi:-1;
    }
};
