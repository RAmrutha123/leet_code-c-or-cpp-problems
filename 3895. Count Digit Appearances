class Solution {
public:
    int countDigitOccurrences(vector<int>& nums, int digit) {
        int c = 0;
        for (int num : nums) {
            if (num == 0 && digit == 0) {
                c++;
            }
            while (num > 0) {
                if (num % 10 == digit)
                    c++;
                num /= 10;
            }
        }

        return c;
    }
};
