class Solution {
public:
    bool areOccurrencesEqual(string s) {
        int n=s.size();
        int c=0;
        int freq[26]={0};
        for(int i=0;i<n;i++){
            freq[s[i]-'a']++;
        }
        for(int i=0;i<26;i++){
            if(freq[i]!=0){
                c=freq[i];
                break;
            }
        }
        for(int i=0;i<26;i++){
            if(freq[i]!=0 && freq[i]!=c){
                return false;
            }
        } 
        return true;      
    }
};
