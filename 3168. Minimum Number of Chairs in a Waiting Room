class Solution {
public:
    int minimumChairs(string s) {
        int n=s.size();
        int c=0;
        int ans=0;
        for(int i=0;i<n;i++){
            if(s[i]=='E'){
                c++;
            }
            else if(s[i]=='L'){
                c--;
            }
            ans = max(ans,c);
        }  
        return ans; 
    }
};
