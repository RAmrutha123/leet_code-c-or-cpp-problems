class Solution {
public:
    int minSteps(string s, string t) {
        vector<int> scount(26,0);
        vector<int> tcount(26,0);

        for(char ch:s){
            scount[ch-'a']++;
        }

        for(char ch:t){
            tcount[ch-'a']++;
        }
        int totalsteps=0;
        for(int i=0;i<26;i++){
            totalsteps+=abs(scount[i]-tcount[i]);
        }
        return totalsteps;
    }
};
